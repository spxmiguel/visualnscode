{
  "name": "visualnscode",
  "version": "0.1.0",
  "private": true,
  "description": "Uma IDE desktop orientada por IA, simples para começar e poderosa para evoluir.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "dompurify@<3.4.12": "3.4.12",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "tmp@<0.2.6": "0.2.7",
      "uuid@<11.1.1": "11.1.1"
    }
  },
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "changeset": "changeset",
    "docs:screenshots": "node scripts/capture-desktop-screenshots.mjs",
    "check:structure": "node scripts/check-workspace.mjs",
    "dev": "pnpm --filter @visualnscode/desktop dev",
    "dev:desktop": "pnpm --filter @visualnscode/desktop dev",
    "dev:landing": "pnpm --filter @visualnscode/landing dev",
    "dev:ui": "pnpm --filter @visualnscode/ui-docs dev",
    "dependencies:audit": "pnpm audit",
    "docs:check": "node scripts/check-docs.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "postinstall": "node scripts/ensure-node-pty-helper.mjs",
    "prepare": "husky",
    "security:audit": "node scripts/audit-repository.mjs",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:coverage": "pnpm test:coverage:unit && pnpm test:coverage:integration",
    "test:coverage:integration": "vitest run --config vitest.integration.config.ts --coverage",
    "test:coverage:unit": "vitest run --config vitest.unit.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:lighthouse": "pnpm --filter @visualnscode/landing build && lhci autorun",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && pnpm -r --if-present typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@changesets/cli": "^2.27.10",
    "@lhci/cli": "^0.15.1",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
